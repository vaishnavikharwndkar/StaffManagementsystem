@model IEnumerable<StaffTaskManagement.Models.Notification>
@using StaffTaskManagement.Models
@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Notifications</h3>
    <form asp-action="MarkAllRead" method="post">
        <button type="submit" class="btn btn-outline-secondary btn-sm">Mark all as read</button>
    </form>
</div>

<div class="list-group">
    @if (!Model.Any())
    {
        <div class="alert alert-info">You have no notifications.</div>
    }
    else
    {
        foreach (var n in Model)
        {
            <a href="@(n.TaskItemId.HasValue ? Url.Action("Details", "Tasks", new { id = n.TaskItemId }) : "#")"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-start @(n.IsRead ? "" : "list-group-item-primary")">
                <div class="ms-2 me-auto">
                    <div class="fw-bold">@n.Type</div>
                    <div>@n.Message</div>
                    @if (n.TaskItem != null)
                    {
                        <small class="text-muted">Task: @n.TaskItem.Title</small>
                    }
                </div>
                <span class="badge bg-light text-muted rounded-pill">
                    @n.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                </span>
            </a>
        }
    }
</div>

