@model IEnumerable<StaffTaskManagement.Models.TaskItem>
@using StaffTaskManagement.Models
@{
    ViewData["Title"] = "Team Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Team Tasks</h3>
    <a asp-controller="Tasks" asp-action="Create" class="btn btn-primary">Create Task</a>
</div>

<p class="text-muted">
    This list shows tasks in your department and tasks you created. Use it to monitor workload
    and follow up on overdue or high-priority work.
</p>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Title</th>
                <th>Assignee</th>
                <th>Department</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Due Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.AssignedTo?.FullName ?? "-"</td>
                <td>@item.Department?.Name ?? "-"</td>
                <td>
                    <span class="badge bg-@(item.Priority switch { TaskPriority.Low => "success", TaskPriority.Medium => "primary", TaskPriority.High => "warning text-dark", TaskPriority.Critical => "danger", _ => "secondary" })">
                        @item.Priority
                    </span>
                </td>
                <td>
                    <span class="badge bg-@(item.Status == StaffTaskManagement.Models.TaskStatus.Completed ? "success" : item.Status == StaffTaskManagement.Models.TaskStatus.InProgress ? "primary" : item.Status == StaffTaskManagement.Models.TaskStatus.OnHold ? "warning text-dark" : item.Status == StaffTaskManagement.Models.TaskStatus.Cancelled ? "secondary" : "info")">
                        @item.Status
                    </span>
                </td>
                <td>@item.DueDate?.ToLocalTime().ToString("dd MMM yyyy")</td>
                <td class="text-end">
                    <a asp-controller="Tasks" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                    <a asp-controller="Tasks" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

