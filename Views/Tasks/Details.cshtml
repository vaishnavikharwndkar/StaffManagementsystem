@model StaffTaskManagement.Models.TaskItem
@using StaffTaskManagement.Models
@{
    ViewData["Title"] = "Task Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>@Model.Title</h3>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Edit</a>
        }
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-3 shadow-sm border-0">
            <div class="card-body">
                <p class="text-muted">@Model.Description</p>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Assigned To</dt>
                    <dd class="col-sm-9">@Model.AssignedTo?.FullName ?? "-"</dd>

                    <dt class="col-sm-3">Priority</dt>
                    <dd class="col-sm-9">@Model.Priority</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@Model.Status</dd>

                    <dt class="col-sm-3">Due Date</dt>
                    <dd class="col-sm-9">@Model.DueDate?.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Created By</dt>
                    <dd class="col-sm-9">@Model.CreatedBy?.FullName</dd>
                </dl>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Comments</h5>
            </div>
            <div class="card-body">
                <div class="mb-3" style="max-height: 250px; overflow-y: auto;">
                    @if (Model.Comments != null && Model.Comments.Any())
                    {
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                        {
                            <div class="mb-2">
                                <div class="small text-muted">
                                    <strong>@comment.Author?.FullName</strong> on @comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                </div>
                                <div>@comment.Content</div>
                            </div>
                            <hr class="my-1" />
                        }
                    }
                    else
                    {
                        <p class="text-muted">No comments yet.</p>
                    }
                </div>
                <form asp-action="AddComment" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-2">
                        <textarea name="content" class="form-control" rows="2" placeholder="Add a comment..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary">Post Comment</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Attachments</h5>
            </div>
            <div class="card-body">
                @if (Model.Attachments != null && Model.Attachments.Any())
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>File</th>
                                    <th>Uploaded By</th>
                                    <th>Uploaded At</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var a in Model.Attachments.OrderByDescending(a => a.UploadedAt))
                            {
                                <tr>
                                    <td>@a.FileName</td>
                                    <td>@a.UploadedBy?.FullName</td>
                                    <td>@a.UploadedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <a asp-action="DownloadAttachment" asp-route-attachmentId="@a.Id" class="btn btn-sm btn-outline-secondary">Download</a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No attachments yet.</p>
                }

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <form asp-action="UploadAttachment" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-2">
                            <input type="file" name="file" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-sm btn-outline-primary">Upload File</button>
                    </form>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4 mt-3 mt-lg-0">
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">Update Status</h5>
            </div>
            <div class="card-body">
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-2">
                        <select name="status" class="form-select">
                            @foreach (StaffTaskManagement.Models.TaskStatus status in Enum.GetValues(typeof(StaffTaskManagement.Models.TaskStatus)))
                            {
                                <option value="@status" selected="@(Model.Status == status)">@status</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-sm btn-outline-primary w-100">Change Status</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0">
                <h5 class="mb-0">History</h5>
            </div>
            <div class="card-body" style="max-height: 200px; overflow-y: auto;">
                @if (Model.Logs != null && Model.Logs.Any())
                {
                    @foreach (var log in Model.Logs.OrderByDescending(l => l.ChangedAt))
                    {
                        <div class="mb-2 small">
                            <div>
                                <strong>@log.FromStatus</strong> → <strong>@log.ToStatus</strong>
                            </div>
                            <div class="text-muted">
                                @log.ChangedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm") by @log.ChangedBy?.FullName
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No history yet.</p>
                }
            </div>
        </div>
    </div>
</div>

